# ---- Frontend environment (sample values only — DO NOT commit real secrets) ----

NODE_ENV=development

# Public port the Next.js app is served on.
PORT=8169

# Internal URL of the private Express backend (server-to-server only, never exposed).
BACKEND_URL=http://127.0.0.1:8170

# Mark the admin auth cookie as `Secure`. Leave false when serving over plain
# HTTP (e.g. http://IP:PORT) — browsers drop Secure cookies on non-HTTPS and
# login will break. Set to true only behind HTTPS.
COOKIE_SECURE=false
