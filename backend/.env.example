# ---- Backend environment (sample values only — DO NOT commit real secrets) ----

# Runtime
NODE_ENV=development
# Private backend port (must NOT be publicly exposed)
PORT=8170
# Bind to loopback so the backend is only reachable internally
HOST=127.0.0.1

# MySQL connection string used by Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/lead_distribution_db"

# JWT signing secret (use a long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET="replace_with_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# Initial admin account created by the seed script
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_me_strong_password"
ADMIN_NAME="Administrator"

# Comma-separated list of allowed origins for the internal API (optional).
# The frontend calls the backend server-to-server, so this is only used as a safety net.
CORS_ORIGIN="http://localhost:8169"
